{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "concurrently \"npm run server:dev\" \"npm run expo:dev\"",
    "expo:dev": "npx expo start --tunnel",
    "expo:web": "npx expo start --web",
    "server:dev": "NODE_ENV=development tsx server/index.ts",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=cjs --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "start": "npx expo start",
    "start:tunnel": "npx expo start --tunnel",
    "start:lan": "npx expo start --lan",
    "start:mobile": "npx expo start --lan --clear",
    "preview:web": "npx expo start --web --clear",
    "eas:dev": "eas build --profile development --platform all",
    "eas:dev:ios": "eas build --profile development --platform ios",
    "eas:dev:android": "eas build --profile development --platform android",
    "eas:preview": "eas build --profile preview --platform all",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "setup": "node scripts/setup-env.js",
    "setup:railway": "node scripts/setup-railway-vars.js",
    "e2e:build:ios": "detox build --configuration ios.sim.release",
    "e2e:build:android": "detox build --configuration android.emu.release",
    "e2e:ios": "detox test --configuration ios.sim.release",
    "e2e:android": "detox test --configuration android.emu.release",
    "e2e:clean": "detox clean-framework-cache && detox build-framework-cache",
    "test:load": "k6 run server/load-tests/k6-baseline.js"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "^2.11.4",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.83.0",
    "@types/axios": "^0.9.36",
    "@ungap/structured-clone": "^1.3.0",
    "axios": "^1.13.6",
    "bullmq": "^5.70.1",
    "cloudflared": "^0.7.1",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.11",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "~4.0.29",
    "expo-font": "~14.0.10",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.0.1",
    "geoip-lite": "^2.0.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.9.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tsx": "^4.20.6",
    "ws": "^8.18.0",
    "yahoo-finance2": "^3.13.2",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@expo/ngrok": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.14",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/react": "~19.1.10",
    "@types/ws": "^8.18.1",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "0.25.12",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "patch-package": "^8.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true
}
